<!-- Hero Header -->
<header class="hero">
  <div class="hero-content">
    <img src="/images/DFD.jpg" alt="Diamond Finish Detailing Logo" class="logo">
    <h1 class="hero-title">Diamond Finish Detailing</h1>
    <p class="hero-subtitle">Professional mobile & shop detailing — restoring shine, protecting value.</p>
    <a href="/booking" class="btn btn-primary">Book Your Service</a>
  </div>
  <div class="hero-overlay"></div>
</header>

<!-- Main Content -->
<main>
  <!-- About Section -->
  <section class="section about-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">About Us</h2>
        <div class="title-underline"></div>
      </div>
      <div class="about-content">
        <p class="about-text">
          We are a young company that works to provide the best service possible to our customers.
          Diamond Finish is not just a company that encourages hard work, but also encourages young
          entrepreneurship and helps other kids get into entrepreneurship.
        </p>
        <!-- Gallery -->
        <section class="section gallery-section">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Gallery</h2>
                    <div class="title-underline"></div>
                    <p class="section-description">Before & After photos and examples of recent work.</p>
                </div>
                <div class="gallery-grid">
                    <figure class="gallery-item">
                        <img src="/images/Beforeupdated.png" alt="before" />
                        <figcaption>Before - Interior</figcaption>
                    </figure>
                    <figure class="gallery-item">
                        <img src="/images/Afterupdated.png" alt="After" />
                        <figcaption>After - Interior cleaned</figcaption>
                    </figure>
                    <figure class="gallery-item">
                        <img src="/images/bronco.jpg" alt="exterior" />
                        <figcaption>Exterior clean</figcaption>
                    </figure>
                </div>
            </div>
        </section>

        <!-- Customer Feedback -->
        <section class="section feedback-section">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Customer Feedback</h2>
                    <div class="title-underline"></div>
                    <p class="section-description">Real reviews from our customers.</p>
                </div>
                <div class="feedback-card">
                  <div class="review">
                    <p class="review-text">"My truck hadn't been detailed in over a year and these guys made it look brand new. The interior was spotless — got every crease and cup holder. Highly recommend."</p>
                    <p class="review-author">— Jake M., Noblesville IN</p>
                  </div>
                  <div class="review">
                    <p class="review-text">"Booked a Level 2 detail for my wife's SUV as a birthday gift. She thought I bought a new car. Great work, very professional, and they came right to the house."</p>
                    <p class="review-author">— Brian T., Fishers IN</p>
                  </div>
                  <div class="review">
                    <p class="review-text">"Super easy to book online and they showed up on time. My car looks incredible. Will definitely be using them every few months."</p>
                    <p class="review-author">— Ashley R., Carmel IN</p>
                  </div>
                </div>
            </div>
        </section>
        <div class="about-features">
          <div class="feature-card">
            <div class="feature-icon">⭐</div>
            <h3>Premium Quality</h3>
            <p>Using only the finest products and techniques</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🚗</div>
            <h3>Mobile Service</h3>
            <p>We come to you for ultimate convenience</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">💎</div>
            <h3>Attention to Detail</h3>
            <p>Every inch of your vehicle gets our care</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section contact-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Contact Us</h2>
        <div class="title-underline"></div>
      </div>
      <div class="contact-card">
        <div class="contact-info">
          <div class="contact-item">
            <div class="contact-icon">📍</div>
            <div>
              <h3>Location</h3>
              <p>Noblesville, IN 46062</p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">📞</div>
            <div>
              <h3>Phone</h3>
              <p><a href="tel:+13176066747">(317) 606-6747</a></p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">⏰</div>
            <div>
              <h3>Hours</h3>
              <p>Mon-Fri: 4:00 PM - 10:00 PM</p>
            </div>
          </div>
        </div>
        <div class="contact-cta">
          <p>Ready to give your vehicle the treatment it deserves?</p>
          <a href="/booking" class="btn btn-secondary">Schedule Now</a>
        </div>
      </div>
    </div>
  </section>
</main>
