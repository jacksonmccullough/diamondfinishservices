.<!-- Main Content -->
<main class="booking-page">
  <!-- Services Section -->
  <section class="section services-section">
    <div class="container">
      <div class="section-header">
        <h1 class="section-title">Our Services</h1>
        <div class="title-underline"></div>
        <p class="section-description">
          We offer a range of packages with base services and premium additives to protect and enhance every area of your vehicle.
        </p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-badge">Essential</div>
          <h2 class="service-title">Level 1 (Detailing)</h2>
          <div class="service-price">$75</div>
          <ul class="service-features">
            <li>✓ Exterior wash & wax</li>
            <li>✓ Interior deep cleaning</li>
            <li>✓ Tire shine</li>
            <li>✓ Window cleaning</li>
          </ul>
        </div>

        <div class="service-card featured">
          <div class="service-badge premium">Premium</div>
          <h2 class="service-title">Level 2 (Detailing)</h2>
          <div class="service-price">$150</div>
          <div class="service-subtitle">Everything in Level 1, plus:</div>
          <ul class="service-features">
            <li>✓ Carpet shampoo</li>
            <li>✓ Scent removal</li>
            <li>✓ Ceramic coating</li>
            <li>✓ Exterior deep clean</li>
            <li>✓ Engine bay cleaning</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- Booking Section -->
  <section class="section booking-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Book Your Appointment</h2>
        <div class="title-underline"></div>
        <p class="section-description">
          Select an available time slot below and complete your reservation. Click reserved slots to view or cancel.
        </p>
      </div>

      <div id="schedule-wrapper">
        <h3 class="schedule-title">Upcoming Schedule</h3>

        <div class="schedule-container">
          <div id="schedule-grid" class="schedule-grid" role="table">
            <!-- Dynamically populated by buildGrid() -->
          </div>
        </div>

        <div class="legend">
          <strong>Legend:</strong>
          <span class="legend-item legend-available">Available</span>
          <span class="legend-item legend-reserved">Reserved</span>
        </div>
      </div>

      <!-- Cancellation Section -->
      <div id="cancel-section" style="margin-top: 2rem; background: var(--card); padding: 2rem; border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); border: 1px solid var(--border); text-align: center;">
        <h3 style="margin-bottom: 0.5rem;">Cancel a Reservation</h3>
        <p style="color: var(--muted-foreground); margin-bottom: 1rem;">Enter the order number from your confirmation text to cancel your booking.</p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <input type="text" id="cancelOrderInput" placeholder="e.g. DF-A3K9M2X1" class="modal-input" style="display: inline-block; max-width: 300px; text-transform: uppercase;">
          <button id="cancelByOrderBtn" class="btn btn-danger">Cancel Reservation</button>
        </div>
      </div>
    </div>
  </section>
</main>

<!-- Custom Modal -->
<div id="customModal" class="modal-overlay">
  <div class="modal-content">
    <h3 id="modalTitle" class="modal-title"></h3>
    <p id="modalMessage" class="modal-message"></p>
    <input type="text" id="modalInput" class="modal-input" style="display: none;">
    <select id="modalSelect" class="modal-input" style="display: none;">
      <option value="">-- Select a Service --</option>
      <option value="Level 1">Level 1 (Detailing - $75)</option>
      <option value="Level 2">Level 2 (Detailing - $150)</option>
    </select>
    <div class="modal-buttons">
      <button id="modalConfirm" class="btn btn-primary">OK</button>
      <button id="modalCancel" class="btn btn-outline" style="display: none;">Cancel</button>
    </div>
  </div>
</div>

<script nonce="{{cspNonce}}">
  // ─── Rolling window configuration ───
  const WINDOW_SIZE = 10; // next 10 weekdays displayed

  const TIME_SLOTS = [
    { key: '16-18', label: '4:00 - 6:00 PM' },
    { key: '18-20', label: '6:00 - 8:00 PM' },
    { key: '20-22', label: '8:00 - 10:00 PM' }
  ];

  let bookings = [];

  // Returns an array of the next `count` weekday Date objects starting from today
  function getNextWeekdays(count) {
    const dates = [];
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    let cursor = new Date(today);
    while (dates.length < count) {
      const dow = cursor.getDay();
      if (dow >= 1 && dow <= 5) {
        dates.push(new Date(cursor));
      }
      cursor.setDate(cursor.getDate() + 1);
    }
    return dates;
  }

  // Format a Date as YYYY-MM-DD (used as the canonical slot key)
  function formatDateKey(d) {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  // Format a Date as a compact column header, e.g. "Mon 5/6"
  function formatDateLabel(d) {
    const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    return dayNames[d.getDay()] + ' ' + (d.getMonth() + 1) + '/' + d.getDate();
  }

  // Format a YYYY-MM-DD string as a readable date for confirmations
  function formatDateFull(dateStr) {
    const [y, m, d] = dateStr.split('-').map(Number);
    const dateObj = new Date(y, m - 1, d);
    const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
    return dayNames[dateObj.getDay()] + ', ' + dateObj.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
  }

  // Build the schedule grid dynamically and attach slot click listeners
  function buildGrid() {
    const grid = document.getElementById('schedule-grid');
    const windowDates = getNextWeekdays(WINDOW_SIZE);
    const colStyle = `grid-template-columns: 140px repeat(${windowDates.length}, minmax(110px, 1fr))`;

    // Update title with date range
    const first = windowDates[0];
    const last = windowDates[windowDates.length - 1];
    const opts = { month: 'short', day: 'numeric' };
    document.querySelector('.schedule-title').textContent =
      'Upcoming Schedule (' + first.toLocaleDateString('en-US', opts) + ' \u2013 ' + last.toLocaleDateString('en-US', opts) + ')';

    let html = '';

    // Header row
    html += `<div class="grid-row grid-header" style="${colStyle}">`;
    html += '<div class="grid-cell grid-time-col">Time</div>';
    windowDates.forEach(function(d) {
      html += '<div class="grid-cell">' + formatDateLabel(d) + '</div>';
    });
    html += '</div>';

    // Time-slot rows
    TIME_SLOTS.forEach(function(slot) {
      html += `<div class="grid-row" style="${colStyle}">`;
      html += '<div class="grid-cell grid-time-col">' + slot.label + '</div>';
      windowDates.forEach(function(d) {
        const dateKey = formatDateKey(d);
        html += '<div class="grid-cell">' +
          '<div class="slot available" data-date="' + dateKey + '" data-time="' + slot.key + '">' +
          '<div class="slot-time">' + slot.label + '</div>' +
          '<div class="slot-status">Available</div>' +
          '</div></div>';
      });
      html += '</div>';
    });

    grid.innerHTML = html;

    // Attach click handlers to all newly created slots
    grid.querySelectorAll('.slot').forEach(function(cell) {
      cell.addEventListener('click', handleSlotClick);
    });
  }

  // Custom Modal Functions
  function showModal(title, message, type, inputPlaceholder) {
    type = type || 'alert';
    inputPlaceholder = inputPlaceholder || '';
    return new Promise(function(resolve) {
      const modal = document.getElementById('customModal');
      const modalTitle = document.getElementById('modalTitle');
      const modalMessage = document.getElementById('modalMessage');
      const modalInput = document.getElementById('modalInput');
      const modalSelect = document.getElementById('modalSelect');
      const confirmBtn = document.getElementById('modalConfirm');
      const cancelBtn = document.getElementById('modalCancel');

      modalTitle.textContent = title;
      modalMessage.textContent = message;
      modalInput.style.display = 'none';
      modalSelect.style.display = 'none';

      if (type === 'select') {
        modalSelect.style.display = 'block';
        modalSelect.value = '';
        cancelBtn.style.display = 'inline-block';
        confirmBtn.textContent = 'Submit';
      } else if (type === 'prompt') {
        modalInput.style.display = 'block';
        modalInput.value = '';
        modalInput.placeholder = inputPlaceholder;
        cancelBtn.style.display = 'inline-block';
        confirmBtn.textContent = 'Submit';
      } else if (type === 'confirm') {
        cancelBtn.style.display = 'inline-block';
        confirmBtn.textContent = 'Yes';
        cancelBtn.textContent = 'No';
      } else {
        cancelBtn.style.display = 'none';
        confirmBtn.textContent = 'OK';
      }

      modal.classList.add('active');

      function handleConfirm() {
        modal.classList.remove('active');
        confirmBtn.removeEventListener('click', handleConfirm);
        cancelBtn.removeEventListener('click', handleCancel);
        if (type === 'select') {
          resolve(modalSelect.value || null);
        } else if (type === 'prompt') {
          resolve(modalInput.value.trim());
        } else {
          resolve(true);
        }
      }

      function handleCancel() {
        modal.classList.remove('active');
        confirmBtn.removeEventListener('click', handleConfirm);
        cancelBtn.removeEventListener('click', handleCancel);
        if (type === 'prompt' || type === 'select') {
          resolve(null);
        } else {
          resolve(false);
        }
      }

      confirmBtn.addEventListener('click', handleConfirm);
      cancelBtn.addEventListener('click', handleCancel);

      if (type === 'prompt') {
        setTimeout(function() { modalInput.focus(); }, 100);
      }
    });
  }

  async function fetchBookings() {
    try {
      const res = await fetch('/api/bookings', { cache: 'no-store' });
      if (!res.ok) {
        bookings = [];
        return;
      }
      const data = await res.json();
      bookings = Array.isArray(data) ? data : [];
    } catch (e) {
      console.error('Failed to fetch bookings', e);
      bookings = [];
    }
  }

  function findBooking(date, time) {
    return bookings.find(function(b) { return b.date === date && b.time === time; });
  }

  function render() {
    document.querySelectorAll('.slot').forEach(function(cell) {
      const date = cell.dataset.date;
      const time = cell.dataset.time;
      const r = findBooking(date, time);
      const human = humanTimeLabel(time);

      if (r) {
        cell.classList.remove('available');
        cell.classList.add('reserved');
        cell.innerHTML = '<div class="slot-time">' + human + '</div><div class="slot-status"><strong>Reserved</strong></div>';
      } else {
        cell.classList.remove('reserved');
        cell.classList.add('available');
        cell.innerHTML = '<div class="slot-time">' + human + '</div><div class="slot-status">Available</div>';
      }
    });
  }

  function humanTimeLabel(time) {
    switch (time) {
      case '16-18': return '4:00 - 6:00 PM';
      case '18-20': return '6:00 - 8:00 PM';
      case '20-22': return '8:00 - 10:00 PM';
      default: return time;
    }
  }

  function validatePhone(phone) {
    if (!phone) return false;
    const digits = phone.replace(/\D/g, '');
    // Accept exactly 10 digits (US) or 11 digits starting with country code 1
    if (digits.length === 11 && digits[0] !== '1') return false;
    if (digits.length !== 10 && digits.length !== 11) return false;
    // Only allow valid formatting characters (digits, spaces, +, -, ., parentheses)
    return /^[+\d\s().\-]+$/.test(phone.trim());
  }

  const VALID_SERVICES = ['Level 1', 'Level 2'];

  function validateService(svc) {
    return svc && VALID_SERVICES.includes(svc);
  }

  function validateName(name) {
    if (!name) return false;
    const t = name.trim();
    if (t.length < 2 || t.length > 50) return false;
    const re = /^[A-Za-z][A-Za-z' -]{0,48}[A-Za-z]$/;
    return re.test(t);
  }

  function validateEmail(email) {
    if (!email) return false;
    const e = email.trim();
    // Reject consecutive dots anywhere
    if (e.includes('..')) return false;
    // Local part must start and end with alphanumeric; domain requires alphabetic TLD (2+ chars)
    const re = /^[a-zA-Z0-9]([a-zA-Z0-9._%+\-]*[a-zA-Z0-9])?@[a-zA-Z0-9]([a-zA-Z0-9\-]*[a-zA-Z0-9])?(\.[a-zA-Z0-9]([a-zA-Z0-9\-]*[a-zA-Z0-9])?)*\.[a-zA-Z]{2,}$/;
    return re.test(e);
  }

  async function handleSlotClick() {
    const date = this.dataset.date;
    const time = this.dataset.time;
    const existing = findBooking(date, time);
    const displayDate = formatDateFull(date);

    if (existing) {
      await showModal(
        'Slot Reserved',
        'This time slot is already reserved.\nService: ' + (existing.service || 'N/A')
      );
      return;
    }

    let name = null;
    for (let attempts = 0; attempts < 3; attempts++) {
      const n = await showModal('Enter Your Name', 'Please enter your full name (letters, spaces, hyphens, apostrophes):', 'prompt', 'John Doe');
      if (!n) { await showModal('Cancelled', 'Reservation cancelled - name is required.'); break; }
      if (validateName(n)) { name = n.trim(); break; }
      await showModal('Invalid Name', 'Name not valid. Use letters, spaces, hyphens or apostrophes (2-50 chars).');
    }
    if (!name) return;

    let phone = null;
    for (let attempts = 0; attempts < 3; attempts++) {
      const p = await showModal('Enter Phone Number', 'Please enter your phone number:', 'prompt', '(317) 555-0123');
      if (!p) { await showModal('Cancelled', 'Reservation cancelled - phone is required.'); break; }
      if (validatePhone(p)) { phone = p.trim(); break; }
      await showModal('Invalid Phone', 'Phone number not valid. Please enter a 10-digit US number, e.g. (317) 555-0123.');
    }
    if (!phone) return;

    let email = null;
    for (let attempts = 0; attempts < 3; attempts++) {
      const e = await showModal('Enter Your Email', 'Please enter your email address for your confirmation:', 'prompt', 'john@example.com');
      if (!e) { await showModal('Cancelled', 'Reservation cancelled - email is required.'); break; }
      if (validateEmail(e)) { email = e.trim(); break; }
      await showModal('Invalid Email', 'Please enter a valid email address.');
    }
    if (!email) return;

    let city = null;
    for (let attempts = 0; attempts < 3; attempts++) {
      const c = await showModal('Enter Your City', 'Please enter your city:', 'prompt', 'Noblesville');
      if (!c) { await showModal('Cancelled', 'Reservation cancelled - city is required.'); break; }
      if (c.trim().length >= 2) { city = c.trim(); break; }
      await showModal('Invalid City', 'Please enter a valid city name (at least 2 characters).');
    }
    if (!city) return;

    const service = await showModal('Select Service', 'Choose the service you would like:', 'select');
    if (!service || !validateService(service)) {
      if (service === null) {
        await showModal('Cancelled', 'Reservation cancelled.');
      } else {
        await showModal('Invalid Service', 'Please select a valid service.');
      }
      return;
    }

    try {
      const res = await fetch('/api/bookings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, phone, city, service, date, time })
      });
      const data = await res.json();
      if (!res.ok) {
        await showModal('Error', data.error || 'Failed to create booking.');
        return;
      }
      await fetchBookings();
      render();
      await showModal(
        'Booking Confirmed!',
        'Order #: ' + data.orderNumber + '\n\nReservation for ' + name + ' on ' + displayDate + ' (' + humanTimeLabel(time) + ').\n\nA confirmation email has been sent to ' + email + '. Save your order number to cancel if needed.'
      );
    } catch (err) {
      await showModal('Error', 'Could not connect to server. Please try again.');
    }
  }

  document.addEventListener('DOMContentLoaded', async function() {
    await fetchBookings();
    buildGrid();
    render();

    // Cancel by order number button
    document.getElementById('cancelByOrderBtn').addEventListener('click', async function() {
      const orderInput = document.getElementById('cancelOrderInput');
      const orderNumber = orderInput.value.trim().toUpperCase();
      if (!orderNumber) {
        await showModal('Error', 'Please enter your order number to cancel.');
        return;
      }
      if (!/^DF-[A-Z0-9]{8}$/.test(orderNumber)) {
        await showModal('Invalid Order Number', 'Order numbers look like DF-A3K9M2X1. Please check and try again.');
        return;
      }
      const confirmed = await showModal('Confirm Cancellation', 'Are you sure you want to cancel order ' + orderNumber + '?', 'confirm');
      if (!confirmed) return;

      try {
        const delRes = await fetch('/api/bookings/cancel', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orderNumber: orderNumber })
        });
        const delData = await delRes.json();
        if (!delRes.ok) {
          await showModal('Error', delData.error || 'Failed to cancel booking.');
          return;
        }
        orderInput.value = '';
        await fetchBookings();
        render();
        await showModal('Cancelled', delData.message + '\n\nOrder ' + orderNumber + ' has been removed.');
      } catch (err) {
        await showModal('Error', 'Could not connect to server. Please try again.');
      }
    });
  });
</script>
